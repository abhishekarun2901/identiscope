  inset: 0;
  background:
    radial-gradient(ellipse 80% 50% at 10% 20%, rgba(6, 182, 212, 0.07) 0%, transparent 60%),
    radial-gradient(ellipse 60% 40% at 90% 80%, rgba(139, 92, 246, 0.07) 0%, transparent 60%);
  pointer-events: none;
  z-index: 0;
}

#root {
  position: relative;
  z-index: 1;
}

/* Glassmorphism card */
.glass-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  backdrop-filter: blur(12px);
  border-radius: 16px;
  transition: background 0.2s, border-color 0.2s, transform 0.2s;
}

.glass-card:hover {
  background: var(--bg-card-hover);
  border-color: var(--border-bright);
}

/* Gradient text */
.gradient-text {
  background: var(--accent-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* Gradient button */
.btn-primary {
  background: var(--accent-gradient);
  color: white;
  border: none;
  border-radius: 12px;
  font-weight: 600;
  font-size: 1rem;
  padding: 0.75rem 2rem;
  cursor: pointer;
  transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
  position: relative;
  overflow: hidden;
}

.btn-primary::after {
  content: '';
  position: absolute;
  inset: 0;
  background: white;
  opacity: 0;
  transition: opacity 0.2s;
}

.btn-primary:hover::after {
  opacity: 0.08;
}

.btn-primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 8px 24px rgba(6, 182, 212, 0.3);
}

/* Header badge live dot */
@keyframes badgeDot {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.header-badge::before {
  content: '';
  display: inline-block;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--status-found);
  margin-right: 0.4em;
  vertical-align: middle;
  animation: badgeDot 1.4s ease-in-out infinite;
}

.btn-primary:active {
  transform: translateY(0);
}

.btn-primary:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none;
  box-shadow: none;
}

/* Input styles */
.input-field {
  background: var(--bg-card);
  border: 1px solid var(--border);
  color: var(--text-primary);
  border-radius: 10px;
  padding: 0.625rem 1rem;
  font-size: 0.9rem;
  font-family: 'Inter', sans-serif;
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
  width: 100%;
}

.input-field:focus {
  border-color: var(--accent-cyan);
  box-shadow: 0 0 0 3px rgba(6, 182, 212, 0.15);
}

.input-field::placeholder {
  color: var(--text-muted);
}

/* Tag styles */
.tag {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.25rem 0.625rem;
  border-radius: 6px;
  font-size: 0.8rem;
  font-weight: 500;
  background: rgba(6, 182, 212, 0.15);
  border: 1px solid rgba(6, 182, 212, 0.3);
  color: var(--accent-cyan);
  white-space: nowrap;
}

.tag.email {
  background: rgba(139, 92, 246, 0.15);
  border-color: rgba(139, 92, 246, 0.3);
  color: #a78bfa;
}

.tag.phone {
  background: rgba(16, 185, 129, 0.15);
  border-color: rgba(16, 185, 129, 0.3);
  color: #34d399;
}

.tag-remove {
  cursor: pointer;
  font-size: 1rem;
  line-height: 1;
  opacity: 0.7;
  transition: opacity 0.15s;
  background: none;
  border: none;
  color: inherit;
  padding: 0;
}

.tag-remove:hover {
  opacity: 1;
}

/* Status badges */
.badge {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.25rem 0.75rem;
  border-radius: 999px;
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.badge.found {
  background: rgba(16, 185, 129, 0.15);
  color: var(--status-found);
  border: 1px solid rgba(16, 185, 129, 0.3);
}

.badge.not_found {
  background: rgba(239, 68, 68, 0.12);
  color: var(--status-not-found);
  border: 1px solid rgba(239, 68, 68, 0.25);
}

.badge.uncertain {
  background: rgba(245, 158, 11, 0.12);
  color: var(--status-uncertain);
  border: 1px solid rgba(245, 158, 11, 0.25);
}

.badge.error {
  background: rgba(107, 114, 128, 0.12);
  color: var(--status-error);
  border: 1px solid rgba(107, 114, 128, 0.25);
}

/* Progress bar */
@keyframes shimmer {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(400%); }
}

.progress-bar {
  width: 100%;
  height: 4px;
  background: var(--bg-card);
  border-radius: 999px;
  overflow: hidden;
  position: relative;
}

.progress-bar .fill {
  position: absolute;
  inset: 0;
  background: var(--accent-gradient);
  animation: shimmer 1.5s infinite;
  width: 30%;
}

/* Platform checkbox tiles */
.platform-tile {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 0.75rem;
  border-radius: 10px;
  border: 1px solid var(--border);
  background: var(--bg-card);
  cursor: pointer;
  transition: border-color 0.2s, background 0.2s, transform 0.15s;
  font-size: 0.82rem;
  font-weight: 500;
  color: var(--text-secondary);
  user-select: none;
}

.platform-tile:hover {
  background: var(--bg-card-hover);
  border-color: var(--border-bright);
  color: var(--text-primary);
  transform: translateY(-1px);
}

.platform-tile.selected {
  border-color: var(--accent-cyan);
  background: rgba(6, 182, 212, 0.1);
  color: var(--text-primary);
}

/* Risk Report Cards */
.risk-cards {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1.25rem;
}

.risk-card {
  padding: 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.risk-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.risk-badge {
  font-size: 0.75rem;
  font-weight: 700;
  padding: 0.3rem 0.6rem;
  border-radius: 6px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  white-space: nowrap;
}

.risk-badge.high { background: rgba(239, 68, 68, 0.15); color: var(--status-not-found); border: 1px solid rgba(239, 68, 68, 0.3); }
.risk-badge.medium { background: rgba(245, 158, 11, 0.15); color: var(--status-uncertain); border: 1px solid rgba(245, 158, 11, 0.3); }
.risk-badge.low { background: rgba(16, 185, 129, 0.15); color: var(--status-found); border: 1px solid rgba(16, 185, 129, 0.3); }
.risk-badge.none { background: rgba(107, 114, 128, 0.15); color: var(--text-secondary); border: 1px solid rgba(107, 114, 128, 0.3); }

.risk-body {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.risk-stats {
  display: flex;
  align-items: baseline;
  gap: 0.4rem;
}

.risk-count {
  font-size: 2rem;
  font-weight: 800;
  line-height: 1;
  color: var(--text-primary);
}

.risk-card.risk-high .risk-count { color: var(--status-not-found); }
.risk-card.risk-medium .risk-count { color: var(--status-uncertain); }
.risk-card.risk-low .risk-count { color: var(--status-found); }

.risk-text {
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--text-secondary);
}

.risk-total {
  font-size: 0.75rem;
  color: var(--text-muted);
  margin-left: auto;
}

.risk-recommendations p {
  margin: 0;
  font-size: 0.8rem;
  line-height: 1.5;
  color: var(--text-secondary);
  background: var(--bg-card);
  padding: 0.75rem;
  border-radius: 8px;
  border: 1px solid var(--border);
}

.risk-recommendations strong {
  color: var(--text-primary);
}

/* Scrollable table wrapper */
.table-wrapper {
  overflow-x: auto;
  border-radius: 16px;
  border: 1px solid var(--border);
}

table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.875rem;
}

thead th {
  padding: 0.875rem 1rem;
  text-align: left;
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--text-muted);
  border-bottom: 1px solid var(--border);
  background: var(--bg-card);
  white-space: nowrap;
}

tbody tr {
  border-bottom: 1px solid var(--border);
  transition: background 0.15s;
}

tbody tr:last-child {
  border-bottom: none;
}

tbody tr:hover {
  background: var(--bg-card);
}

tbody td {
  padding: 0.75rem 1rem;
  color: var(--text-secondary);
  vertical-align: middle;
}

/* Animations */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(16px); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in-up {
  animation: fadeInUp 0.4s ease forwards;
}

@keyframes pulse-dot {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.pulse-dot {
  animation: pulse-dot 1.2s infinite;
}

/* Scrollbar */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: var(--border-bright);
  border-radius: 99px;
}

/* Hide header badge + subtitle on very small screens */
@media (max-width: 480px) {
  .header-badge { display: none !important; }
  .header-subtitle { display: none !important; }
}

/* ────────────────────────────────────────────────────────────
   RESPONSIVE LAYOUT
   ──────────────────────────────────────────────────────────── */

/* Two-column input + platform grid */
.responsive-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
  gap: 1.5rem;
  align-items: start;
}

/* Scan button row */
.scan-row {
  display: flex;
  align-items: center;
  gap: 0.875rem;
  flex-wrap: wrap;
}

/* Stat cards (results summary) */
.stat-cards {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0.75rem;
  margin-bottom: 1.25rem;
}

/* Mobile card results (hidden on desktop) */
.results-cards-mobile {
  display: none;
}

/* ── Tablet (≤ 900px) ── */
@media (max-width: 900px) {
  .responsive-grid {
    grid-template-columns: 1fr;
  }

  .stat-cards {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* ── Mobile (≤ 640px) ── */
@media (max-width: 640px) {
  main {
    padding: 1rem 0.875rem !important;
  }

  h2 {
    font-size: clamp(1.35rem, 7vw, 1.9rem) !important;
  }

  .btn-primary {
    width: 100%;
    text-align: center;
    padding: 0.875rem 1.5rem;
  }

  .scan-row {
    flex-direction: column;
    align-items: stretch;
  }

  .scan-row > * {
    width: 100%;
    text-align: center;
  }

  .stat-cards {
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }

  /* Show card layout, hide table on mobile */
  .results-table-wrapper {
    display: none !important;
  }

  .results-cards-mobile {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* Group header stays visible */
  .group-header-btn {
    font-size: 0.82rem !important;
  }

  /* Filter bar: stack vertically */
  .filter-bar {
    flex-direction: column;
    align-items: stretch;
  }

  .filter-bar > input,
  .filter-bar > select {
    max-width: 100% !important;
    margin-left: 0 !important;
  }

  .filter-btn-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  footer {
    font-size: 0.7rem !important;
    padding: 0.75rem 1rem !important;
  }
}

/* ── Very small phones (≤ 380px) ── */
@media (max-width: 380px) {
  .stat-cards {
    grid-template-columns: 1fr 1fr;
  }
}

/* Safe-area insets for notched phones */
@supports (padding-bottom: env(safe-area-inset-bottom)) {
  footer {
    padding-bottom: calc(1rem + env(safe-area-inset-bottom)) !important;
  }
}

/* Touch-friendly tap targets */
@media (pointer: coarse) {
  .platform-tile {
    padding: 0.625rem 0.875rem;
    min-height: 44px;
  }

  .btn-primary {
    min-height: 48px;
  }

  .tag-remove {
    min-width: 28px;
    min-height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
}

/* ── Mobile result card ── */
.result-card-mobile {
  padding: 0.875rem 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  border-radius: 12px;
}

.result-card-mobile-header {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.result-card-mobile-identity {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
  font-family: 'Menlo', 'Monaco', 'Consolas', monospace;
  font-size: 0.82rem;
  color: var(--text-secondary);
  padding-left: 0.1rem;
}

.result-card-mobile-footer {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
  margin-top: 0.125rem;
}

/* ── Snippet pre on both views ── */
.snippet-pre {
  font-size: 0.72rem;
  color: var(--text-muted);
  margin: 0;
  white-space: pre-wrap;
  word-break: break-word;
  max-height: 120px;
  overflow-y: auto;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 8px;
  padding: 0.5rem;
  font-family: 'Menlo', 'Monaco', 'Consolas', monospace;
}
